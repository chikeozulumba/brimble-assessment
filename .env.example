DATABASE_URL=postgres://bimbo:bimbo@db:5432/bimbo
CADDY_ADMIN_URL=http://caddy:2019
APPS_NETWORK=bimbo_apps
PUBLIC_BASE_URL=http://localhost:8080
# Registry used to avoid "sending tarball" hang with remote BuildKit (set automatically by docker-compose).
REGISTRY_PUSH_HOST=registry:5000
REGISTRY_RUN_HOST=localhost:5000
RAILPACK_FRONTEND=ghcr.io/railwayapp/railpack-frontend:v0.23.0
# Optional: RAILPACK_VERBOSE=1 for more Railpack output
RAILPACK_VERBOSE=
